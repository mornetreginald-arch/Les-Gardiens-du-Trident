<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Les Gardiens du Trident{% endblock %}
		</title>
		<link rel="icon" href="{{ asset('images/Logo.png') }}"> 

		

		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}
	</head>
	<body>
		<header>
			<nav>
				<ul>
					{% if is_granted('ROLE_ADMIN') %}
						<div class="admin-tools" style="border: 1px solid red; padding: 10px; display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
							<strong>Panneau Admin :</strong>
							<a href="{{ path('app_articles_new') }}">Ajouter un Article</a>
							<a href="{{ path('app_chiots_new') }}">Ajouter un Chiot</a>
                            <a href="{{ path('app_categorie_new') }}">Ajouter une Categorie</a>
							<a href="{{ path('app_commande_index') }}">Modifier/Supprimer une commande</a>
						</div>
					{% endif %}
					{% if app.user %}
						<li>
							<a href="{{ path('app_articles_index') }}">Articles</a>
						</li>
						<li>
							<a href="{{ path('app_panier') }}">Panier</a>
						</li>
						<li>
							<a href="{{ path('app_user') }}">Mon profil</a>
						</li>
						<li>
							<a href="{{ path('app_logout') }}">Se deconnecter</a>
						</li>

					{% else %}
						<li>
							<a href="{{ path('app_login') }}">Se connecter</a>
						</li>
						<li>
							<a href="{{ path('app_register') }}">S'inscrire</a>
						</li>
					{% endif %}
				</ul>
			</nav>
		</header>


		{% block body %}{% endblock %}
	</body>
</html>
