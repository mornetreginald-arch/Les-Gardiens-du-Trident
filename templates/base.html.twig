<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta
		name="viewport" content="width=device-width, initial-scale=1.0">

		<!-- Google Font -->
		<link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&display=swap" rel="stylesheet">

		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

		<!-- Font Awesome -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

		<title>
			{% block title %}Les Gardiens du Trident
			{% endblock %}
		</title>

		<link rel="icon" href="{{ asset('images/logo.png') }}">

		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}
	</head>

	<body class="{% block body_class %}{% endblock %}">

		<header>
			<nav class="nav_container">

				<div class="nav-links">
					<ul class="nav-list">

						<a href="{{ path('app_home') }}" class="navbar-brand">
							<img src="{{ asset('images/logo.png') }}" alt="Logo Mon Élevage" width="150">
						</a>

						<li>
							<a href="{{ path('app_elevage') }}">NOTRE ÉLEVAGE</a>
						</li>
						<li>
							<a href="{{ path('app_geant') }}">NOS GÉANTS</a>
						</li>
						<li>
							<a href="{{ path('app_quotidient') }}">LE QUOTIDIEN</a>
						</li>
						<li>
							<a href="{{ path('app_contact') }}">CONTACT</a>
						</li>
						<li>
							<a href="{{ path('app_articles_index') }}" class="nav-btn">DISPONIBILITÉ DES CHIOTS</a>
						</li>
					</ul>
				</div>

				<!-- Navigation utilisateur -->
				<div class="nav-user">

					{% if app.user %}

						{% set totalArticles = 0 %}

						{% if panier is defined and panier %}
							{% for ligne in panier.lignePaniers %}
								{% set totalArticles = totalArticles + ligne.quantite %}
							{% endfor %}
						{% endif %}

						<button class="btn btn-outline-light position-relative" data-bs-toggle="modal" data-bs-target="#panierModal">

							Panier

							{% if totalArticles > 0 %}
								<span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
									{{ totalArticles }}
								</span>
							{% endif %}
						</button>

					
				</button>

				<a href="{{ path('app_user') }}">Mon profil</a>
				<a href="{{ path('app_logout') }}">Se déconnecter</a>
				{% endif %}
			</div>

			<!-- Admin -->
			{% if is_granted('ROLE_ADMIN') %}
				<div class="nav-admin">
					<span>Panneau Admin :</span>
					<a href="{{ path('app_articles_new') }}">Ajouter un Article</a>
					<a href="{{ path('app_chiots_new') }}">Ajouter un Chiot</a>
					<a href="{{ path('app_categorie_new') }}">Ajouter une Catégorie</a>
					<a href="{{ path('app_commande_index') }}">Commandes</a>
				</div>
			{% endif %}

		</nav>
	</body>
</header>
<main>
{% block body %}{% endblock %}</main><footer class="site_footer">

<div class="footer-title">
	<h2>LES GARDIENS DU TRIDENT</h2>
</div>

<div class="footer-content">

	<div class="footer-column">
		<h4>NAVIGATION</h4>
		<ul>
			<li><a href="{{path('app_elevage')}}">Notre Élevage</a></li>
			<li><a href="{{path('app_geant')}}">Nos Géants</a></li>
			<li><a href="{{path('app_quotidient')}}">Le Quotidien</a></li>
			<li><a href="{{path('app_contact')}}">Contact</a></li>
		</ul>
	</div>

	<div class="footer-column">
		<h4>INFORMATIONS</h4>
		<ul>
			<li>Conditions Générales</li>
			<li>Politique de Confidentialité</li>
		</ul>
	</div>

	<div class="footer-column">
		<h4>RÉSEAUX SOCIAUX</h4>
		<div class="social-icons">
			<img src="{{ asset('images/logo-instagram.svg') }}" alt="Instagram" width="30">
			<img src="{{ asset('images/logo-whatsapp.svg') }}" alt="Whatsapp" width="30">
		</div>
	</div>

</div>

<div class="footer-logo">
	<a href="{{ path('app_home') }}" class="navbar-brand">
		<img src="{{ asset('images/logo.png') }}" alt="Logo Mon Élevage" width="150">
	</a>
</div></footer><script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script><!-- Modal Login Global --><div class="modal fade" id="loginModal" tabindex="-1">
<div class="modal-dialog">
	<div class="modal-content">

		<div class="modal-header">
			<h5 class="modal-title">Connexion</h5>
			<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
		</div>

		<div class="modal-body">

			{% if error is defined and error %}
				<div class="alert alert-danger">
					{{ error.messageKey|trans(error.messageData, 'security') }}
				</div>
			{% endif %}

			<form method="post" action="{{ path('app_login') }}">

				<div class="mb-3">
					<input type="email" name="_username" class="form-control" placeholder="Email" value="{{ last_username|default('') }}" required>
				</div>

				<div class="mb-3">
					<input type="password" name="_password" class="form-control" placeholder="Mot de passe" required>
				</div>

				<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

				<button type="submit" class="btn btn-success w-100">
					Se connecter
				</button>

				<div class="text-center mt-3">
					<button class="btn btn-link" data-bs-target="#registerModal" data-bs-toggle="modal" data-bs-dismiss="modal">
						Pas encore de compte ? S'inscrire
					</button>
				</div>

			</form>

		</div>

	</div>
</div></div><!-- Modal Inscription --><div class="modal fade" id="registerModal" tabindex="-1">
<div class="modal-dialog">
	<div class="modal-content">

		<div class="modal-header">
			<h5 class="modal-title">Inscription</h5>
			<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
		</div>

		<div class="modal-body">

			<form method="post" action="{{ path('app_register') }}">

				<div class="row">
					<div class="col-md-6 mb-3">
						<input type="text" name="registration_form[nom]" class="form-control" placeholder="Nom" required>
					</div>

					<div class="col-md-6 mb-3">
						<input type="text" name="registration_form[prenom]" class="form-control" placeholder="Prénom" required>
					</div>
				</div>

				<div class="mb-3">
					<input type="email" name="registration_form[email]" class="form-control" placeholder="Email" required>
				</div>

				<div class="mb-3">
					<input type="text" name="registration_form[telephone]" class="form-control" placeholder="Téléphone" required>
				</div>

				<div class="mb-3">
					<input type="text" name="registration_form[rue]" class="form-control" placeholder="Rue" required>
				</div>

				<div class="row">
					<div class="col-md-4 mb-3">
						<input type="text" name="registration_form[code_postal]" class="form-control" placeholder="Code Postal" required>
					</div>

					<div class="col-md-4 mb-3">
						<input type="text" name="registration_form[ville]" class="form-control" placeholder="Ville" required>
					</div>

					<div class="col-md-4 mb-3">
						<input type="text" name="registration_form[pays]" class="form-control" placeholder="Pays" required>
					</div>
				</div>

				<div class="mb-3">
					<input type="password" name="registration_form[plainPassword]" class="form-control" placeholder="Mot de passe" required>
				</div>

				<button type="submit" class="btn btn-success w-100">
					S'inscrire
				</button>

			</form>

		</div>

	</div>
</div></div><!-- Modal Panier --><div class="modal fade" id="panierModal" tabindex="-1">
<div class="modal-dialog modal-lg">
	<div class="modal-content">

		<div class="modal-header">
			<h5 class="modal-title">Mon Panier</h5>
			<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
		</div>

		<div class="modal-body">

			{% if panier is defined and panier and panier.lignePaniers|length > 0 %}

				{% set total = 0 %}

				<ul class="list-group mb-3">
					{% for ligne in panier.lignePaniers %}

						{% if ligne.articles %}
							{% set prix = ligne.articles.prix %}
							{% set nom = ligne.articles.nomProduit %}
						{% elseif ligne.chiot %}
							{% set prix = ligne.chiot.prix %}
							{% set nom = 'Chiot ' ~ ligne.chiot.sexe %}
						{% endif %}

						{% set total = total + (prix * ligne.quantite) %}

						<li class="list-group-item d-flex justify-content-between align-items-center">

							<div>
								<strong>{{ nom }}</strong><br>
								{{ prix }}
								€ x
								{{ ligne.quantite }}
							</div>

							<a href="{{ path('app_panier_remove', {id: ligne.id}) }}" class="btn btn-sm btn-danger">
								✕
							</a>

						</li>

					{% endfor %}
				</ul>

				<div class="text-end">
					<h5>Total :
						<strong>{{ total }}
							€</strong>
					</h5>
				</div>

				<div class="text-end mt-3">
					<a href="{{ path('app_panier_valider') }}" class="btn btn-success">
						Valider mon panier
					</a>
				</div>

			{% else %}
				<p class="text-center">Votre panier est vide.</p>
			{% endif %}
		</div>
	</div>

</body>
</html>
