{% extends 'base.html.twig' %}

{% block title %}Commande index{% endblock %}

{% block body %}
    <h1>Commande index</h1>

    <table class="table">
        <thead>
            <tr>
                {# <th>Id</th>
                <th>Id_commande</th> #}
                <th>Date_commande</th>
                <th>Quantite</th>
                <th>Total</th>
                {# <th>Prix_unitaire</th> #}
                {# <th>actions</th> #}
            </tr>
        </thead>
        <tbody>
        {% for commande in commandes %}
            <tr>
                {# <td>{{ commande.id }}</td>
                <td>{{ commande.idCommande }}</td> #}
                <td>{{ commande.dateCommande ? commande.dateCommande|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ commande.quantite }}</td>
                <td>{{ commande.total }}</td>
                {# <td>{{ commande.prixUnitaire }}</td> #}
                <td>
                    <a href="{{ path('app_commande_show', {'id': commande.id}) }}">Voir/Modifier votre commande</a>
                    {# <a href="{{ path('app_commande_edit', {'id': commande.id}) }}">edit</a> #}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_commande_new') }}">Create new</a>
{% endblock %}
