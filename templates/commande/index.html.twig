{% extends 'base.html.twig' %}

{% block title %}Commandes
{% endblock %}

{% block body %}

	{# Vérifie si l'utilisateur est admin #}
	{% if is_granted('ROLE_ADMIN') %}

		<h1>Commandes par utilisateur</h1>

		{# Boucle sur tous les utilisateurs #}
		{% for user in users %}

			{# Vérifie si l'utilisateur a des commandes #}
			{% if user.commandes|length > 0 %}
				<hr>

				{# Infos utilisateur #}
				<h2>{{ user.prenom }}
					{{ user.nom }}
					({{ user.email }})</h2>

				{# Boucle sur les commandes de cet utilisateur #}
				{% for commande in user.commandes %}

					{# Infos commande #}
					<p>
						Commande #{{ commande.id }}
						-
						{{ commande.dateCommande|date('d/m/Y') }}
						-
						{{ commande.total|number_format(2, ',', ' ') }} €
					</p>

					{# Liste des éléments de la commande #}
					<ul>

						{# Boucle sur les lignes de commande #}
						{% for ligne in commande.ligneCommandes %}
							<li>

								{# Si c'est un article #}
								{% if ligne.articles %}
									{{ ligne.articles.nomProduit }}

								{# Si c'est un chiot #}
								{% elseif ligne.chiot %}
									Chiot -
									{{ ligne.chiot.sexe }}
									(Collier
									{{ ligne.chiot.couleurCollier }})
								{% endif %}
								— Quantité :
								{{ ligne.quantite }}
							</li>
						{% endfor %}
					</ul>

					{# Formulaire de suppression de commande (admin uniquement) #}
					<form method="post" action="{{ path('app_commande_delete', {'id': commande.id}) }}" onsubmit="return confirm('Supprimer cette commande ?');">

						{# Protection CSRF #}
						<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ commande.id) }}">

						{# Bouton suppression #}
						<button class="btn btn-danger btn-sm">Supprimer</button>
					</form>

				{% endfor %}
			{% endif %}
		{% endfor %}

	{% else %}

		{# Partie utilisateur classique (non admin) #}
		<h1>Mes commandes</h1>

		{# Boucle sur les commandes de l'utilisateur connecté #}
		{% for commande in commandes %}

			<p>
				Commande #{{ commande.id }}
				-
				{{ commande.dateCommande|date('d/m/Y') }}
				-
				{{ commande.total }}
				€
			</p>

			<ul>

				{# Boucle sur les lignes de commande #}
				{% for ligne in commande.ligneCommandes %}
					<li>
						{% if ligne.articles %}
							{{ ligne.articles.nomProduit }}
						{% elseif ligne.chiot %}
							Chiot -
							{{ ligne.chiot.sexe }}
							(Collier
							{{ ligne.chiot.couleurCollier }})
						{% endif %}
						— Quantité :
						{{ ligne.quantite }}
					</li>
				{% endfor %}
			</ul>

		{# Si aucune commande #}
		{% else %}
			<p>Aucune commande trouvée.</p>
		{% endfor %}

	{% endif %}

{% endblock %}
