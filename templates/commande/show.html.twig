{% extends 'base.html.twig' %}

{% block title %}Commande{% endblock %}

{% block body %}
    <h1>Commande</h1>

    {# Tableau affichant les informations de la commande #}
    <table class="table">
        <tbody>

            <tr>
                {# Ligne : date de la commande #}
                <th>Date_commande</th>

                {# Affiche la date si elle existe, sinon rien #}
                <td>{{ commande.dateCommande ? commande.dateCommande|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>

                {# Ligne : total de la commande #}
                <th>Total</th>
                <td>{{ commande.total }}</td>
            </tr>
            
        </tbody>
    </table>

    {# Lien pour revenir à la liste des commandes #}
    <a href="{{ path('app_commande_index') }}">Retour à la liste</a>

    {# Si l'utilisateur est admin, affiche le formulaire de suppression #}
    {% if is_granted('ROLE_ADMIN') %}
    {{ include('commande/_delete_form.html.twig') }}
    {% endif %}
{% endblock %}
