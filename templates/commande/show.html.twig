{% extends 'base.html.twig' %}

{% block title %}Commande{% endblock %}

{% block body %}
    <h1>Commande</h1>

    <table class="table">
        <tbody>
            {# <tr>
                <th>Id</th>
                <td>{{ commande.id }}</td>
            </tr> #}
            {# <tr>
                <th>articles</th>
                <td>{{ commande.nomProduit }}</td>
            </tr> #}
            <tr>
                <th>Date_commande</th>
