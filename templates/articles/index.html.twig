{% extends 'base.html.twig' %}

{% block title %}Articles index
{% endblock %}

{% block body %}


	<table class="table">
		<thead>
			<h1>Articles</h1>
			<tr>
				<th>Nom_produit</th>
				<th>Prix</th>
				<th>Image</th>
				<th>Action</th>
			</tr>
		</thead>

		<tbody>

			{# ================= ARTICLES ================= #}
			{% for article in articles %}
				<tr>
					<td>{{ article.nomProduit }}</td>
					<td>{{ article.prix }}€</td>
					<td>
						{% if article.image %}
							<img src="{{ asset('uploads/' ~ article.image) }}" width="100">
						{% else %}
							<span class="text-muted">Pas d'image</span>
						{% endif %}
					</td>

					<td>

						{# 🔥 Affichage stock restant #}
						{% if article.stock > 0 %}
							{% if article.stock <= 3 %}
								<small class="text-danger d-block">Plus que
									{{ article.stock }}
									en stock !</small>
							{% else %}
								<small class="text-muted d-block">Stock restant :
									{{ article.stock }}</small>
							{% endif %}
						{% endif %}

						{# 🔥 Gestion rupture comme chiot #}
						{% if article.stock <= 0 %}
							<span class="text-danger fw-bold">Rupture de stock</span>
							{% else %}
							{# <a href="{{ path('app_cart_add', {'id': article.id}) }}" class="btn btn-sm btn-success">Ajouter</a> #}
						{% endif %}

						{% if is_granted('ROLE_ADMIN') %}
							<div class="mt-1">
								<a href="{{ path('app_articles_edit', {'id': article.id}) }}">Modifier</a>
							</div>
						{% endif %}

						{% if article.prix <= 0 %}
							<span class="text-muted">Inclus avec réservation</span>

						{% else %}

							{% if app.user %}
								<a href="{{ path('app_cart_add', {'id': article.id}) }}" class="btn btn-sm btn-success">
									Ajouter
								</a>
							{% else %}
								<button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#loginModal">
									Ajouter
								</button>
							{% endif %}

						{% endif %}

					</td>
				</tr>

			{% else %}
				<tr>
					<td colspan="4">Aucun article trouvé</td>
				</tr>
			{% endfor %}

			{# ================= CHIOTS ================= #}

			<table class="table">
				<thead>
					<h2>Chiots</h2>
					<tr>
						<th>Sexe</th>
						<th>Prix</th>
						<th>Collier</th>
						<th>Image</th>
						<th>Réservation</th>
					</tr>
				</thead>
				<tbody>
					{% for chiot in chiots %}
						<tr>
							<td>{{ chiot.sexe }}
								(Chiot)</td>
							<td>{{ chiot.prix }}
								€</td>
							<td>{{ chiot.couleurCollier }}</td>

							<td>
								{% if chiot.image %}
									<img src="{{ asset('uploads/' ~ chiot.image) }}" width="100">
								{% else %}
									Pas d'image
								{% endif %}
							</td>

							<td>
								{% if chiot.estVendu %}
									<span class="text-danger fw-bold">Déjà réservé</span>

								{% else %}

									{% if app.user %}
										<a href="{{ path('app_cart_add_chiot', {'id': chiot.id}) }}" class="btn btn-warning btn-sm">
											Réserver
										</a>
									{% else %}
										<button type="button" class="btn btn-warning btn-sm" data-bs-toggle="modal" data-bs-target="#loginModal">
											Réserver
										</button>
									{% endif %}

								{% endif %}
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</tbody>


		<!-- Modal Login -->
		<div class="modal fade" id="loginModal" tabindex="-1">
			<div class="modal-dialog">
				<div class="modal-content">

					<div class="modal-header">
						<h5 class="modal-title">Connexion requise</h5>
						<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
					</div>

					<div class="modal-body text-center">
						<p>Vous devez être connecté pour ajouter un article au panier.</p>

						<a href="{{ path('app_login') }}" class="btn btn-primary w-100">
							Se connecter
						</a>
					</div>

				</div>
			</div>
		</div>
	{% endblock %}
