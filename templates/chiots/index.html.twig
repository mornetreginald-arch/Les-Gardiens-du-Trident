{% extends 'base.html.twig' %}

{% block title %}Liste des chiots{% endblock %}

{% block body %}
	<h1>Chiots index</h1>

	{# Tableau Bootstrap pour afficher les chiots #}
	<table class="table">

		{# En-tête du tableau #}
		<thead>
			<tr>
				<th>Sexe</th>
				<th>Couleur collier</th>
				<th>Image</th>
				<th>Prix</th>
				<th>Réservation</th>
				<th>Action</th>
			</tr>
		</thead>
		<tbody>

			{# Boucle sur tous les chiots #}
			{% for chiot in chiots %}
				<tr>
					<td>{{ chiot.sexe }}</td>
					<td>{{ chiot.couleurCollier }}</td>

					<td>
						{% if chiot.image %}
							<img src="{{ asset('uploads/' ~ chiot.image) }}" width="100">
						{% else %}
							Pas d'image
						{% endif %}
					</td>

					<td>{{ chiot.prix|number_format(2, ',', ' ') }} €</td>

					{# Bouton réservation ou statut vendu #}
					<td>
						{% if not chiot.estVendu %}
							<a href="{{ path('app_cart_add_chiot', {'id': chiot.id}) }}" class="btn btn-success btn-sm">
								Réserver
							</a>

						{# Affiche si déjà vendu #}
						{% else %}
							<span class="text-danger">Déjà vendu</span>
						{% endif %}
					</td>

					<td>
						<a href="{{ path('app_chiots_edit', {'id': chiot.id}) }}">
							Modifier
						</a>
					</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

	{# Lien pour ajouter un nouveau chiot #}
	<a href="{{ path('app_chiots_new') }}">Ajouter un nouveau chiot</a>

{% endblock %}
